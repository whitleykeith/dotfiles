#!/bin/bash
# css — Codespace manager
# Usage:
#   css                     List all codespaces, pick one to SSH into
#   css <repo>              SSH into codespace for repo (creates if none exist)
#   css ls                  List all codespaces
#   css rm [repo]           Delete a codespace (prompts to pick)
#   css rebuild [repo]      Rebuild a codespace (full rebuild)
#   css stop [repo]         Stop a running codespace
#   css start [repo]        Start a stopped codespace
#   css create <repo>       Create a new codespace
#   css logs [repo]         View creation logs for a codespace
#   css web [repo]          Open a codespace in VS Code web

set -e

CMD="$1"
ARG="$2"

# ── Helpers ──

list_codespaces() {
  local repo_filter="$1"
  local args=(--json name,repository,state,displayName,createdAt)
  [ -n "$repo_filter" ] && args+=(--repo "$repo_filter")
  gh codespace list "${args[@]}" \
    --jq '.[] | "\(.name)\t\(.repository)\t\(.state)\t\(.displayName)"' | \
    column -t -s $'\t' | nl -ba
}

pick_codespace() {
  local repo_filter="$1"
  local prompt="${2:-Pick a number (or q to quit): }"
  local args=(--json name,state)
  [ -n "$repo_filter" ] && args+=(--repo "$repo_filter")

  local data
  data=$(gh codespace list "${args[@]}")
  local count
  count=$(echo "$data" | jq 'length')

  if [ "$count" -eq 0 ]; then
    echo "No codespaces found."
    return 1
  fi

  list_codespaces "$repo_filter"
  echo ""
  read -rp "$prompt" choice
  [ "$choice" = "q" ] && exit 0

  local idx=$((choice - 1))
  CS_NAME=$(echo "$data" | jq -r ".[$idx].name")
  CS_STATE=$(echo "$data" | jq -r ".[$idx].state")

  if [ -z "$CS_NAME" ] || [ "$CS_NAME" = "null" ]; then
    echo "❌ Invalid selection"
    return 1
  fi
}

ssh_into() {
  local name="$1" state="$2"
  if [ "$state" != "Available" ]; then
    echo "⏳ Starting codespace..."
    gh codespace start -c "$name" 2>/dev/null || true
  fi
  echo "🔗 Connecting to $name..."
  gh codespace ssh -c "$name"
}

# ── Commands ──

cmd_ls() {
  echo "Your codespaces:"
  echo ""
  list_codespaces "$ARG"
}

cmd_rm() {
  echo "Select codespace to delete:"
  pick_codespace "$ARG" "Pick a number to delete (or q to quit): " || exit 1
  echo ""
  read -rp "⚠️  Delete $CS_NAME? (y/n): " confirm
  [ "$confirm" = "y" ] || exit 0
  gh codespace delete -c "$CS_NAME" -f
  echo "🗑️  Deleted $CS_NAME"
}

cmd_rebuild() {
  echo "Select codespace to rebuild:"
  pick_codespace "$ARG" "Pick a number to rebuild (or q to quit): " || exit 1
  echo ""
  read -rp "⚠️  Full rebuild $CS_NAME? This destroys and recreates the container. (y/n): " confirm
  [ "$confirm" = "y" ] || exit 0
  gh codespace rebuild -c "$CS_NAME" --full
  echo "🔨 Rebuild started for $CS_NAME"
}

cmd_stop() {
  echo "Select codespace to stop:"
  pick_codespace "$ARG" "Pick a number to stop (or q to quit): " || exit 1
  gh codespace stop -c "$CS_NAME"
  echo "⏹️  Stopped $CS_NAME"
}

cmd_start() {
  echo "Select codespace to start:"
  pick_codespace "$ARG" "Pick a number to start (or q to quit): " || exit 1
  gh codespace start -c "$CS_NAME"
  echo "▶️  Started $CS_NAME"
}

cmd_create() {
  local repo="${ARG:-$1}"
  if [ -z "$repo" ]; then
    read -rp "Repo (e.g. github/github): " repo
  fi
  echo "🆕 Creating codespace for $repo..."
  gh codespace create --repo "$repo" --status
  echo "✅ Created. Run 'css $repo' to SSH in."
}

cmd_logs() {
  echo "Select codespace to view logs:"
  pick_codespace "$ARG" "Pick a number (or q to quit): " || exit 1
  gh codespace logs -c "$CS_NAME"
}

cmd_web() {
  echo "Select codespace to open in browser:"
  pick_codespace "$ARG" "Pick a number (or q to quit): " || exit 1
  gh codespace code -c "$CS_NAME" --web
  echo "🌐 Opened $CS_NAME in browser"
}

cmd_forward() {
  local repo="$1"
  shift 2>/dev/null || true
  local ports=("$@")

  if [ ${#ports[@]} -eq 0 ]; then
    echo "Usage: css forward <repo> <port> [port...]"
    echo "  e.g. css forward github/data-dot 3000"
    echo "       css forward github/data-dot 3000 8080 5432"
    exit 1
  fi

  # Find codespace for repo
  local data
  data=$(gh codespace list --repo "$repo" --json name,state 2>/dev/null)
  local count
  count=$(echo "$data" | jq 'length')

  if [ "$count" -eq 0 ]; then
    echo "❌ No codespaces found for $repo"
    exit 1
  elif [ "$count" -eq 1 ]; then
    CS_NAME=$(echo "$data" | jq -r '.[0].name')
    CS_STATE=$(echo "$data" | jq -r '.[0].state')
  else
    echo "Found $count codespaces for $repo:"
    echo ""
    echo "$data" | jq -r '.[] | "\(.name)\t\(.state)"' | column -t -s $'\t' | nl -ba
    echo ""
    read -rp "Pick a number (or q to quit): " choice
    [ "$choice" = "q" ] && exit 0
    local idx=$((choice - 1))
    CS_NAME=$(echo "$data" | jq -r ".[$idx].name")
    CS_STATE=$(echo "$data" | jq -r ".[$idx].state")
  fi

  if [ "$CS_STATE" != "Available" ]; then
    echo "⏳ Starting codespace..."
    gh codespace start -c "$CS_NAME" 2>/dev/null || true
  fi

  # Build port forward args (space-separated port:port pairs)
  local port_args=()
  for p in "${ports[@]}"; do
    port_args+=("${p}:${p}")
  done

  echo "🔌 Forwarding port(s) ${ports[*]} from $CS_NAME..."
  gh codespace ports forward "${port_args[@]}" -c "$CS_NAME"
}

cmd_ssh() {
  local repo="$1"

  # No repo — list all and pick
  if [ -z "$repo" ]; then
    echo "No repo specified. Listing all codespaces..."
    echo ""
    pick_codespace "" "Pick a number (or q to quit): " || exit 1
    ssh_into "$CS_NAME" "$CS_STATE"
    return
  fi

  # Repo specified — find matching
  local data
  data=$(gh codespace list --repo "$repo" --json name,state,displayName 2>/dev/null)
  local count
  count=$(echo "$data" | jq 'length')

  if [ "$count" -eq 0 ]; then
    echo "🆕 No codespaces found for $repo. Creating one..."
    gh codespace create --repo "$repo" --status
    local name
    name=$(gh codespace list --repo "$repo" --json name --jq '.[0].name')
    ssh_into "$name" "Available"

  elif [ "$count" -eq 1 ]; then
    ssh_into "$(echo "$data" | jq -r '.[0].name')" "$(echo "$data" | jq -r '.[0].state')"

  else
    echo "Found $count codespaces for $repo:"
    echo ""
    echo "$data" | jq -r '.[] | "\(.name)\t\(.state)\t\(.displayName)"' | \
      column -t -s $'\t' | nl -ba
    echo ""
    read -rp "Pick a number (c=create new, q=quit): " choice
    [ "$choice" = "q" ] && exit 0
    if [ "$choice" = "c" ]; then
      cmd_create "$repo"
    else
      local idx=$((choice - 1))
      local name state
      name=$(echo "$data" | jq -r ".[$idx].name")
      state=$(echo "$data" | jq -r ".[$idx].state")
      [ -z "$name" ] || [ "$name" = "null" ] && echo "❌ Invalid selection" && exit 1
      ssh_into "$name" "$state"
    fi
  fi
}

cmd_local() {
  local repo="$1"
  local action="${2:-shell}"

  if [ -z "$repo" ]; then
    echo "Usage: css local <repo> [shell|up|down|rebuild]"
    echo ""
    echo "  css local github/data-dot          Clone, build, and shell in"
    echo "  css local github/data-dot up       Start container (no shell)"
    echo "  css local github/data-dot down     Stop and remove container"
    echo "  css local github/data-dot rebuild  Rebuild from scratch"
    echo "  css local .                        Use current directory"
    exit 1
  fi

  # Check dependencies
  if ! command -v devcontainer &>/dev/null; then
    echo "📦 Installing devcontainer CLI..."
    npm install -g @devcontainers/cli
  fi
  if ! docker info &>/dev/null 2>&1; then
    echo "❌ Docker is not running. Start Docker Desktop or OrbStack first."
    exit 1
  fi

  # Resolve workspace folder
  local workspace
  if [ "$repo" = "." ]; then
    workspace="$(pwd)"
  else
    local repo_name="${repo##*/}"
    workspace="$HOME/git/${repo_name}"
    if [ ! -d "$workspace" ]; then
      echo "📥 Cloning $repo..."
      mkdir -p "$HOME/git"
      gh repo clone "$repo" "$workspace"
    fi
  fi

  if [ ! -f "$workspace/.devcontainer/devcontainer.json" ] && \
     [ ! -f "$workspace/.devcontainer.json" ]; then
    echo "⚠️  No devcontainer.json found in $workspace"
    read -rp "Continue with default config? (y/n): " confirm
    [ "$confirm" = "y" ] || exit 0
  fi

  case "$action" in
    up)
      echo "🔨 Building and starting devcontainer for $workspace..."
      devcontainer up --workspace-folder "$workspace"
      echo "✅ Container running. Use 'css local $repo' to shell in."
      ;;
    down)
      echo "🛑 Stopping devcontainer for $workspace..."
      local container_id
      container_id=$(docker ps -q --filter "label=devcontainer.local_folder=$workspace")
      if [ -n "$container_id" ]; then
        docker rm -f "$container_id"
        echo "✅ Container removed."
      else
        echo "No running container found for $workspace"
      fi
      ;;
    rebuild)
      echo "♻️  Rebuilding devcontainer for $workspace..."
      local container_id
      container_id=$(docker ps -aq --filter "label=devcontainer.local_folder=$workspace")
      [ -n "$container_id" ] && docker rm -f "$container_id"
      devcontainer up --workspace-folder "$workspace" --remove-existing-container
      echo "✅ Rebuilt. Use 'css local $repo' to shell in."
      ;;
    shell|"")
      # Start if not running
      local container_id
      container_id=$(docker ps -q --filter "label=devcontainer.local_folder=$workspace")
      if [ -z "$container_id" ]; then
        echo "🔨 Starting devcontainer for $workspace..."
        devcontainer up --workspace-folder "$workspace"
        container_id=$(docker ps -q --filter "label=devcontainer.local_folder=$workspace")
      fi
      if [ -z "$container_id" ]; then
        echo "❌ Failed to start container"
        exit 1
      fi
      echo "🔗 Connecting to devcontainer..."
      # Prefer zsh, fall back to bash, then sh
      local shell_cmd
      shell_cmd=$(docker exec "$container_id" sh -c 'command -v zsh || command -v bash || echo sh' 2>/dev/null)
      docker exec -it -w /workspaces/"${workspace##*/}" "$container_id" "$shell_cmd"
      ;;
    *)
      echo "Unknown action: $action"
      echo "Use: shell, up, down, or rebuild"
      exit 1
      ;;
  esac
}

# ── Dispatch ──

case "$CMD" in
  ls|list)     cmd_ls ;;
  rm|delete)   cmd_rm ;;
  rebuild)     cmd_rebuild ;;
  stop)        cmd_stop ;;
  start)       cmd_start ;;
  create|new)  cmd_create ;;
  logs)        cmd_logs ;;
  web)         cmd_web ;;
  forward|fwd) cmd_forward "$ARG" "${@:3}" ;;
  local)       cmd_local "$ARG" "${@:3}" ;;
  help|-h|--help)
    echo "css — Codespace manager"
    echo ""
    echo "Usage:"
    echo "  css                     SSH into a codespace (list all, pick one)"
    echo "  css <repo>              SSH into codespace for repo (auto-create)"
    echo "  css ls [repo]           List codespaces"
    echo "  css rm [repo]           Delete a codespace"
    echo "  css rebuild [repo]      Full rebuild a codespace"
    echo "  css stop [repo]         Stop a codespace"
    echo "  css start [repo]        Start a codespace"
    echo "  css create <repo>       Create a new codespace"
    echo "  css logs [repo]         View creation logs"
    echo "  css web [repo]          Open in VS Code web"
    echo "  css forward <repo> <port> [port...]  Forward ports"
    echo "  css local <repo> [shell|up|down|rebuild]  Local devcontainer"
    ;;
  *)           cmd_ssh "$CMD" ;;
esac
